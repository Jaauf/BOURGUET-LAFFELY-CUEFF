# Injection SQL
alert http any any -> any any (msg:"SQL Injection détectée"; flow:to_server,established; http.uri; content:"SELECT"; nocase; pcre:"/(\bSELECT\b.*\bFROM\b|\bUNION\b.*\bSELECT\b|\bDROP\b.*\bTABLE\b)/i"; classtype:web-application-attack; sid:1000001; rev:1;)
alert http any any -> any any (msg:"SQL Injection OR 1=1"; flow:to_server,established; http.uri; content:"or+1=1"; nocase; classtype:web-application-attack; sid:1000002; rev:1;)
alert http any any -> any any (msg:"SQL Injection apostrophe"; flow:to_server,established; http.uri; content:"'"; pcre:"/'\s*(or|and)\s*'?\d/i"; classtype:web-application-attack; sid:1000003; rev:1;)

# Injection de commandes OS (RCE)
alert http any any -> any any (msg:"RCE - cmd injection /etc/passwd"; flow:to_server,established; http.uri; content:"/etc/passwd"; classtype:web-application-attack; sid:1000010; rev:1;)
alert http any any -> any any (msg:"RCE - pipe shell"; flow:to_server,established; http.uri; pcre:"/(\||%7C|%60|`)\s*(bash|sh|cmd|powershell)/i"; classtype:web-application-attack; sid:1000011; rev:1;)
alert http any any -> any any (msg:"RCE - semicolon injection"; flow:to_server,established; http.uri; pcre:"/(;|\%3B)\s*(ls|cat|whoami|id|wget|curl)/i"; classtype:web-application-attack; sid:1000012; rev:1;)

# Path traversal ../
alert http any any -> any any (msg:"Path Traversal ../"; flow:to_server,established; http.uri; content:"../"; classtype:web-application-attack; sid:1000020; rev:1;)
alert http any any -> any any (msg:"Path Traversal encodé %2e%2e"; flow:to_server,established; http.uri; content:"%2e%2e"; nocase; classtype:web-application-attack; sid:1000021; rev:1;)
